# ============================================
# X-Drone 智能售后系统 - 环境变量配置示例
# ============================================
# ⚠️ 安全警告：所有必填项必须正确配置，否则系统无法启动！

# -------------------------
# 数据库连接配置
# -------------------------
# 本地开发使用 SQLite（无需额外配置）
# DATABASE_URL=sqlite:///./local_database.db

# 生产环境使用 PostgreSQL（Supabase / Railway）
# 格式：postgresql://用户名:密码@主机:5432/数据库名
DATABASE_URL=postgresql://your_username:your_password@your_host:5432/your_database

# -------------------------
# AI 服务配置
# -------------------------
# DeepSeek API Key（用于智能客服问答）
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------
# 【必填】安全配置
# -------------------------
# JWT 密钥（用于用户认证）
# ⚠️ 必填项！请使用强随机字符串（至少32位）
# 生成方法：在终端执行 openssl rand -hex 32
# 或使用在线工具：https://www.uuidgenerator.net/
JWT_SECRET=请替换为32位以上的随机字符串

# -------------------------
# 【必填】管理员配置
# -------------------------
# ⚠️ 必填项！初始管理员账号和密码
# 建议：密码至少8位，包含字母+数字+特殊符号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请设置强密码例如Admin123!@#

# -------------------------
# 【必填】CORS安全配置
# -------------------------
# 允许访问的前端域名（多个域名用逗号分隔）
# 本地开发：http://localhost:8000,http://localhost:3000
# 生产环境：https://your-domain.com
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
